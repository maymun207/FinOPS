# ============================================================
# FinOPS — .gitignore
# ============================================================

# Environment files — NEVER commit real secrets
.env
.env.local
.env.*.local
.env.production

# Dependencies
node_modules/
.pnp
.pnp.js

# Build outputs
.next/
out/
dist/
build/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Runtime data
*.pid
*.seed
*.pid.lock

# Testing
coverage/
.nyc_output/

# OS files
.DS_Store
Thumbs.db

# Editor directories and files
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Supabase local dev
supabase/.temp/
supabase/functions/.cache/

# Vercel
.vercel

# Trigger.dev
.trigger/

# Sentry
.sentryclirc

# Misc
*.turbo
~$*
