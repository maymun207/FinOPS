# ============================================================
# FinOPS — Environment Variables Template
# ============================================================
# Copy this file to .env and fill in your own values.
# DO NOT put real secrets in this file.
# ============================================================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
SUPABASE_DB_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-0-eu-west-1.pooler.supabase.com:6543/postgres
# Session pooler (port 5432) — used ONLY by drizzle-kit migrations
# Get from Supabase dashboard → Connect button → Session pooler tab
SUPABASE_DB_URL_UNPOOLED=postgresql://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-0-eu-west-1.pooler.supabase.com:5432/postgres

# Clerk (Authentication)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key

# Trigger.dev (Background Jobs)
TRIGGER_SECRET_KEY=tr_dev_your_trigger_secret_key

# Cloudflare R2 (File Storage)
CLOUDFLARE_R2_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_R2_ACCESS_KEY_ID=your_r2_access_key_id
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
CLOUDFLARE_R2_BUCKET_NAME=finops-imports

# AI & Services
GEMINI_API_KEY=your_gemini_api_key
RESEND_API_KEY=re_your_resend_api_key
AXIOM_TOKEN=your_axiom_token
SENTRY_DSN=https://your_key@o123.ingest.sentry.io/your_project_id
NEXT_PUBLIC_SENTRY_DSN=https://your_key@o123.ingest.sentry.io/your_project_id
# SENTRY_AUTH_TOKEN=sntrys_your_auth_token  (CI only — for source map uploads)
